{
  "name": "web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "npm run build:assets && vite dev",
    "build": "npm run build:assets && vite build",
    "build:assets": "node ./scripts/build-assets.mjs",
    "preview": "vite preview",
    "wasm:build": "wasm-pack build ../../crates/steply-wasm --target nodejs --out-dir ./src/lib/steply-wasm/pkg --out-name steply_wasm",
    "prepare": "svelte-kit sync || echo ''",
    "check": "npm run build:assets && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "npm run build:assets && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/node": "^25.3.3",
    "svelte": "^5.51.0",
    "svelte-check": "^4.4.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.19.0",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.16",
    "codemirror-json-schema": "^0.8.1"
  }
}
