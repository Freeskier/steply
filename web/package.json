{
	"name": "web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"content:build": "bun ./scripts/build-content.mjs",
		"wasm:build": "bun ./scripts/build-wasm.mjs",
		"dev:full": "bun run content:build && bun run wasm:build && bun run dev",
		"build:full": "bun run content:build && bun run wasm:build && bun run build",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-cloudflare": "^7.2.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/node": "^25.3.3",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"wasm-pack": "^0.13.1",
		"wrangler": "^4.37.1"
	},
	"dependencies": {
		"@codemirror/autocomplete": "^6.19.0",
		"@codemirror/lang-yaml": "^6.1.2",
		"@codemirror/lint": "^6.9.5",
		"@codemirror/state": "^6.5.4",
		"@codemirror/theme-one-dark": "^6.1.3",
		"@codemirror/view": "^6.39.16",
		"codemirror-json-schema": "^0.8.1"
	}
}
